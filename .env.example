# Copiar a .env y completar
POSTGRES_PASSWORD=cambia-esto

# OIDC (vacío = modo dev SIN auth, solo para desarrollo local)
CADVCS_OIDC_ISSUER=https://idp.example.com/realms/cad
CADVCS_OIDC_AUDIENCE=cadvcs
# En producción: vacío = deny-by-default para tokens sin claim de roles
CADVCS_DEFAULT_ROLES=

# --- Almacenamiento de blobs (opcional; vacío = disco local) ---
# S3/OCI/MinIO: el servidor sale del path de bytes con presigned (spec 13)
# CADVCS_BLOB_URL=s3://mi-bucket/cadvcs
# CADVCS_S3_ENDPOINT=https://minio.example.com   # para MinIO/OCI compat

# --- Conversión DWG→DXF (opcional; none = DWG como binario opaco) ---
# Valores: aspose (requiere licencia), oda (ODA File Converter), none
CADVCS_DWG_CONVERTER=none
# CADVCS_ODA_BIN=/opt/ODAFileConverter/ODAFileConverter   # si CONVERTER=oda

# --- Cache de renders en Redis (opcional; vacío = recomputa cada vez) ---
CADVCS_REDIS_URL=redis://redis:6379/0

# --- Transporte de eventos por Kafka (opcional; vacío = worker en polling) ---
CADVCS_KAFKA_BROKERS=kafka:9092

# --- Cliente CLI ---
# CADVCS_USER=tu_nombre        # identidad por defecto sin --user ni login
# CADVCS_SERVER=http://localhost:8000   # servidor por defecto para login/token
